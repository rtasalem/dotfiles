{
    "layer": "top",
    "position": "top",
    "margin-top": 6,
    "margin-left": 6,
    "margin-right": 6,
    "margin-bottom": 0,

    // ── Modules Layout ───────────────────────────────────────────────
    "modules-left": [
        "clock",
        "custom/power",
        "network",
        "bluetooth",
        "custom/microphone",
        "custom/vpn"
    ],

    "modules-center": [
        "custom/workspace-1",
        "custom/workspace-2",
        "custom/workspace-3",
        "custom/workspace-4",
        "custom/workspace-5"
    ],

    "modules-right": [
        "custom/battery",
        "custom/volume",
        "custom/brightness"
    ],

    // ── Clock ────────────────────────────────────────────────────────
    "clock": {
        "tooltip-format": "{:%a, %d %b %Y}\n{calendar}",
        "format": "[ {:%H:%M}]"
    },

    // ── Network ──────────────────────────────────────────────────────
    "network": {
        "format-wifi": "{icon}",
        "format-icons": ["[󰤯]", "[󰤟]", "[󰤢]", "[󰤥]", "[󰤨]"],
        "format-ethernet": "[󰀂]",
        "format-alt": "[󱛇]",
        "format-disconnected": "[󰖪]",
        "tooltip-format-wifi": "{icon} {essid}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
        "tooltip-format-ethernet": "󰀂  {ifname}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor",
        "interval": 5
    },

    // ── Bluetooth ────────────────────────────────────────────────────
    "bluetooth": {
        "format": "{icon}",
        "format-icons": {
            "enabled": "[]",
            "disabled": "[󰂲]"
        },
        "on-click": "~/.config/waybar/scripts/bluetooth-toggle.sh",
        "tooltip-format": "Bluetooth is {status}",
        "interval": 5
    },

    // ── Microphone ───────────────────────────────────────────────────
    "custom/microphone": {
        "exec": "~/.config/waybar/scripts/mic.sh",
        "interval": 1,
        "signal": 8,
        "tooltip": true,
        "tooltip-format": "Click to toggle mic mute",
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle && pkill -RTMIN+8 waybar"
    },

    // ── VPN ──────────────────────────────────────────────────────────
    "custom/vpn": {
        "exec": "~/.config/waybar/scripts/nordvpn-status.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "~/.config/waybar/scripts/nordvpn-toggle.sh"
    },

    // ── Power ────────────────────────────────────────────────────────
    "custom/power": {
        "format": "[󰤆]",
        "tooltip": true,
        "tooltip-format": "Power Menu",
        "on-click": "~/.config/waybar/scripts/powermenu.sh"
    },

    // ── Battery ──────────────────────────────────────────────────────
    "custom/battery": {
        "exec": "~/.config/waybar/scripts/battery.sh",
        "return-type": "json",
        "interval": 10
    },

    // ── Volume ───────────────────────────────────────────────────────
    "custom/volume": {
        "exec": "~/.config/waybar/scripts/volume.sh",
        "return-type": "json",
        "interval": 1,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },

    // ── Brightness ───────────────────────────────────────────────────
    "custom/brightness": {
        "exec": "~/.config/waybar/scripts/brightness.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/brightness-toggle.sh",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    // ── Workspaces ───────────────────────────────────────────────────
    "custom/workspace-1": {
        "exec": "~/.config/waybar/scripts/workspaces/workspace-1.sh",
        "interval": 1,
        "on-click": "hyprctl dispatch workspace 1",
        "tooltip": false
    },
    "custom/workspace-2": {
        "exec": "~/.config/waybar/scripts/workspaces/workspace-2.sh",
        "interval": 1,
        "on-click": "hyprctl dispatch workspace 2",
        "tooltip": false
    },
    "custom/workspace-3": {
        "exec": "~/.config/waybar/scripts/workspaces/workspace-3.sh",
        "interval": 1,
        "on-click": "hyprctl dispatch workspace 3",
        "tooltip": false
    },
    "custom/workspace-4": {
        "exec": "~/.config/waybar/scripts/workspaces/workspace-4.sh",
        "interval": 1,
        "on-click": "hyprctl dispatch workspace 4",
        "tooltip": false
    },
    "custom/workspace-5": {
        "exec": "~/.config/waybar/scripts/workspaces/workspace-5.sh",
        "interval": 1,
        "on-click": "hyprctl dispatch workspace 5",
        "tooltip": false
    }
}
